{
  "[github-actions-workflow]": {
    "editor.tabSize": 2
  },
  "[nix]": {
    "editor.tabSize": 2
  },
  "[powershell]": {
    "editor.rulers": [115]
  },
  "[python]": {
    "editor.rulers": [80]
  },
  "[yaml]": {
    "editor.tabSize": 2
  },
  "breadcrumbs.enabled": true,
  "chat.agent.enabled": false,
  "chat.commandCenter.enabled": false,
  "diffEditor.codeLens": true,
  "diffEditor.experimental.showMoves": true,
  "diffEditor.experimental.useTrueInlineView": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.cursorStyle": "line-thin",
  "editor.fontFamily": "Cascadia Mono NF, Menlo, Monaco, 'Courier New', monospace",
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "editor.mouseWheelZoom": true,
  "editor.renderWhitespace": "trailing",
  "editor.scrollbar.horizontal": "visible",
  "editor.scrollBeyondLastLine": false,
  "editor.semanticHighlighting.enabled": true,
  "editor.showFoldingControls": "always",
  "editor.smoothScrolling": true,
  "editor.tabCompletion": "on",
  "editor.wordWrap": "on",
  "explorer.confirmDragAndDrop": false,
  "files.enableTrash": false,
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "git.autofetch": true,
  "git.autofetchPeriod": 900,
  "git.autoStash": true,
  "git.branchProtection": ["main", "master"],
  "git.confirmSync": false,
  "git.discardUntrackedChangesToTrash": false,
  "git.enableSmartCommit": true,
  "git.fetchOnPull": true,
  "git.ignoreRebaseWarning": true,
  "git.mergeEditor": true,
  "git.openAfterClone": "alwaysNewWindow",
  "git.postCommitCommand": "sync",
  "git.replaceTagsWhenPull": true,
  "git.terminalGitEditor": true,
  "git.useCommitInputAsStashMessage": true,
  "javascript.suggest.paths": false,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "markdown.occurrencesHighlight.enabled": true,
  "markdown.validate.enabled": true,
  "markdownlint.config": {
    // This is set to match .mado.toml settings from https://github.com/natescherer/postmodern-repo-copiertemplate/
    "MD048": false,
    "MD049": false,
    "MD050": false,
    "MD051": false,
    "MD052": false,
    "MD053": false,
    "MD054": false
  },
  "merge-conflict.autoNavigateNextConflict.enabled": true,
  "mise.automaticallyTrustMiseConfigFiles": false,
  "mise.checkForNewMiseVersion": false,
  "outline.showVariables": false,
  "powershell.codeFormatting.autoCorrectAliases": true,
  "powershell.codeFormatting.avoidSemicolonsAsLineTerminators": true,
  "powershell.codeFormatting.pipelineIndentationStyle": "IncreaseIndentationForFirstPipeline",
  "powershell.codeFormatting.preset": "OTBS",
  "powershell.codeFormatting.trimWhitespaceAroundPipe": true,
  "powershell.codeFormatting.useCorrectCasing": true,
  "powershell.codeFormatting.whitespaceBetweenParameters": true,
  "python.analysis.autoFormatStrings": true,
  "python.analysis.autoImportCompletions": true,
  "python.analysis.generateWithTypeAnnotation": true,
  "redhat.telemetry.enabled": false,
  "scm.alwaysShowActions": true,
  "search.showLineNumbers": true,
  "search.useIgnoreFiles": false,
  "telemetry.feedback.enabled": false,
  "terminal.integrated.allowChords": false,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.drawBoldTextInBrightColors": false,
  "terminal.integrated.env.windows": {
    "HOME": null // This causes problems with a lot of tools when it gets set on Windows. Can't find what sets it.
  },
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.tabs.location": "left",
  "typescript.suggest.paths": false,
  "workbench.colorCustomizations": {
    "terminal.ansiBlack": "#222222",
    "terminal.ansiBlue": "#2d83e8",
    "terminal.ansiBrightBlack": "#525252",
    "terminal.ansiBrightBlue": "#509af6",
    "terminal.ansiBrightCyan": "#1faeae",
    "terminal.ansiBrightGreen": "#67af34",
    "terminal.ansiBrightMagenta": "#ca64f3",
    "terminal.ansiBrightRed": "#f75b72",
    "terminal.ansiBrightWhite": "#f1f1f1",
    "terminal.ansiBrightYellow": "#c98b1a",
    "terminal.ansiCyan": "#1a9696",
    "terminal.ansiGreen": "#59972d",
    "terminal.ansiMagenta": "#ba3ce8",
    "terminal.ansiRed": "#e73359",
    "terminal.ansiWhite": "#b9b9b9",
    "terminal.ansiYellow": "#ae7714",
    "terminal.background": "#080808",
    "terminal.foreground": "#e2e2e2",
    "terminalCursor.foreground": "#b9b9b9"
  },
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 5,
  "workbench.editor.tabActionUnpinVisibility": false,
  "workbench.fontAliasing": "auto",
  "yaml.extension.recommendations": false,
  "files.autoSave": "afterDelay",
  "window.title": "${rootName} [Profile: ${profileName}] ",
  "vs-kubernetes": {
    "vs-kubernetes.crd-code-completion": "disabled"
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "mise.configureExtensionsAutomatically": false,
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "yaml.disableSchemaDetection": [
    "azure-pipelines.yml",
    "azure-pipelines.yaml"
  ]
}
