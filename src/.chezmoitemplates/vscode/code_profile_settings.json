{
  "[powershell]": {
    "editor.rulers": [
      115
    ]
  },
  "[python]": {
    "editor.rulers": [
      80
    ]
  },
  "[yaml]": {
    "editor.tabSize": 2
  },
  "breadcrumbs.enabled": true,
  "chat.editor.wordWrap": "on",
  "chat.restoreLastPanelSession": true,
  "claudeCode.preferredLocation": "sidebar",
  "diffEditor.codeLens": true,
  "diffEditor.experimental.showMoves": true,
  "diffEditor.experimental.useTrueInlineView": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.autoIndentOnPaste": true,
  "editor.fontFamily": "Cascadia Mono NF, Menlo, Monaco, 'Courier New', monospace",
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "editor.mouseWheelZoom": true,
  "editor.renderWhitespace": "boundary",
  "editor.scrollbar.horizontal": "visible",
  "editor.scrollBeyondLastLine": false,
  "editor.semanticHighlighting.enabled": true,
  "editor.showFoldingControls": "always",
  "editor.smoothScrolling": true,
  "editor.tabCompletion": "on",
  "editor.wordWrap": "on",
  "extensions.ignoreRecommendations": true,
  "files.autoSave": "afterDelay",
  "files.enableTrash": false,
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "git.alwaysSignOff": true,
  "git.autofetch": true,
  "git.autoStash": true,
  "git.branchProtection": [
    "main",
    "master"
  ],
  "git.confirmSync": false,
  "git.discardUntrackedChangesToTrash": false,
  "git.enableSmartCommit": true,
  "git.fetchOnPull": true,
  "git.mergeEditor": true,
  "git.openAfterClone": "alwaysNewWindow",
  "git.postCommitCommand": "sync",
  "git.pruneOnFetch": true,
  "git.replaceTagsWhenPull": true,
  "git.terminalGitEditor": true,
  "git.useCommitInputAsStashMessage": true,
  "html.format.indentInnerHtml": true,
  "js/ts.suggest.paths": false,
  "merge-conflict.autoNavigateNextConflict.enabled": true,
  "mise.checkForNewMiseVersion": false,
  "mise.updateOpenTerminalsEnvAutomatically": true,
  "powershell.codeFormatting.autoCorrectAliases": true,
  "powershell.codeFormatting.avoidSemicolonsAsLineTerminators": true,
  "powershell.codeFormatting.pipelineIndentationStyle": "IncreaseIndentationForFirstPipeline",
  "powershell.codeFormatting.preset": "OTBS",
  "powershell.codeFormatting.trimWhitespaceAroundPipe": true,
  "powershell.codeFormatting.useCorrectCasing": true,
  "powershell.codeFormatting.whitespaceBetweenParameters": true,
  "python.analysis.autoFormatStrings": true,
  "python.analysis.autoImportCompletions": true,
  "python.analysis.generateWithTypeAnnotation": true,
  "redhat.telemetry.enabled": false,
  "remote.defaultExtensionsIfInstalledLocally": [
    "GitHub.copilot",
    "GitHub.copilot-chat",
    "GitHub.vscode-pull-request-github",
    "Anthropic.claude-code"
  ],
  "scm.alwaysShowActions": true,
  "search.showLineNumbers": true,
  "search.useIgnoreFiles": false,
  "telemetry.feedback.enabled": false,
  "terminal.integrated.allowChords": false,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.enableImages": true,
  "terminal.integrated.enableVisualBell": true,
  "terminal.integrated.env.windows": {
    "HOME": null // This causes problems with a lot of tools when it gets set on Windows. Can't find what sets it.
  },
  "terminal.integrated.initialHint": false,
  "terminal.integrated.scrollback": 5000,
  "terminal.integrated.smoothScrolling": true,
  "workbench.colorCustomizations": {
    "terminal.ansiBlack": "#222222",
    "terminal.ansiBlue": "#2d83e8",
    "terminal.ansiBrightBlack": "#525252",
    "terminal.ansiBrightBlue": "#509af6",
    "terminal.ansiBrightCyan": "#1faeae",
    "terminal.ansiBrightGreen": "#67af34",
    "terminal.ansiBrightMagenta": "#ca64f3",
    "terminal.ansiBrightRed": "#f75b72",
    "terminal.ansiBrightWhite": "#f1f1f1",
    "terminal.ansiBrightYellow": "#c98b1a",
    "terminal.ansiCyan": "#1a9696",
    "terminal.ansiGreen": "#59972d",
    "terminal.ansiMagenta": "#ba3ce8",
    "terminal.ansiRed": "#e73359",
    "terminal.ansiWhite": "#b9b9b9",
    "terminal.ansiYellow": "#ae7714",
    "terminal.background": "#080808",
    "terminal.foreground": "#e2e2e2",
    "terminalCursor.foreground": "#b9b9b9"
  },
  "workbench.editor.enablePreview": false,
  "workbench.editor.tabSizing": "shrink",
  "workbench.experimental.modernUI": true,
  "workbench.list.smoothScrolling": true,
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "python.createEnvironment.trigger": "off",
  "workbench.settings.alwaysShowAdvancedSettings": true,
  "workbench.startupEditor": "none",
  "yaml.extension.recommendations": false,
  "yaml.disableSchemaDetection": [
    "**/.github/workflows/*.yml",
    "**/.github/workflows/*.yaml",
    "**/.gitea/workflows/*.yml",
    "**/.gitea/workflows/*.yaml",
    "**/.forgejo/workflows/*.yml",
    "**/.forgejo/workflows/*.yaml",
    "azure-pipelines.yml",
    "azure-pipelines.yaml"
  ]
}
