#!/usr/bin/env python3
# Installs each VS Code profile's extensions (from .chezmoidata/vscode.toml) and, for named
# profiles, syncs their settings.json into VS Code's own (machine-generated) profile folder.
# The Default profile's settings.json is managed directly by the per-OS settings.json.tmpl files.
#
# A named profile's settings.json is only overwritten if it's untouched since the last time this
# script wrote it (tracked via a settings.json.chezmoi-hash sidecar file), so local customizations
# never get clobbered; if drift is detected, it warns instead of overwriting.

import hashlib
import json
import os
import platform
import subprocess
import sys

{{/* The section below embeds the content of .chezmoiscript/vscode.toml as well as the files under
.chezmoitemplates/vscode, ensuring changes to those files will cause the hash of this files to change,
triggering the run_onchange_. */}}
{{- $profiles := list }}
{{- $extensionSets := .vscode.extension_sets | default (dict) }}
{{- range .vscode.profiles }}
{{- $settings := "" }}
{{- $icon := "" }}
{{- if ne .name "Default" }}
{{- $settings = include (printf ".chezmoitemplates/vscode/%s" .settings_file) }}
{{- $icon = .icon }}
{{- end }}
{{- $extensions := list }}
{{- range $extensionSetName := .extension_sets | default (list) }}
{{- $extensionSetExtensions := index $extensionSets $extensionSetName | default (list) }}
{{- range $extension := $extensionSetExtensions }}
{{- $extensions = append $extensions $extension }}
{{- end }}
{{- end }}
{{- range $extension := .extensions | default (list) }}
{{- $extensions = append $extensions $extension }}
{{- end }}
{{- $profiles = append $profiles (dict "name" .name "extensions" $extensions "settings" $settings "icon" $icon) }}
{{- end }}

PROFILES = {{ $profiles | toJson }}

# The below is set via chezmoi templating and serves as both a check to make sure VS Code is installed before
# doing anything, and to ensure the script will change (triggering it to run) when VS Code is installed.
CODE_AVAILABLE = {{ if lookPath "code" }}True{{ else }}False{{ end }}

IS_WINDOWS = platform.system() == "Windows"

# Normally, a profile's settings.json that has drifted from what chezmoi last wrote is left alone
# (see write_profile_settings) so local customizations never get silently clobbered. Setting this
# opts back into always overwriting it with what chezmoi wants instead.
CHEZMOI_VSCODE_CLOBBER = os.environ.get("CHEZMOI_VSCODE_CLOBBER", "").lower() in ("1", "true", "yes")

# Setting an env var for a single command differs by shell, so give the warning below a copy-pasteable
# example matching however this script itself is actually being run.
CLOBBER_COMMAND = (
    '$env:CHEZMOI_VSCODE_CLOBBER = "true"; chezmoi apply'
    if IS_WINDOWS
    else "CHEZMOI_VSCODE_CLOBBER=true chezmoi apply"
)

CYAN_TERM_COLOR = "\033[0;36m"
RED_TERM_COLOR = "\033[0;31m"
YELLOW_TERM_COLOR = "\033[1;33m"
RESET_TERM_STYLE = "\033[0m"


def vscode_user_dir():
    system = platform.system()
    if system == "Windows":
        return os.path.join(os.environ["APPDATA"], "Code", "User")
    if system == "Darwin":
        return os.path.join(os.path.expanduser("~"), "Library", "Application Support", "Code", "User")
    return os.path.join(os.path.expanduser("~"), ".config", "Code", "User")


def run_code(*args):
    # 'code' needs launched through a shell on Windows.
    cmd = ["cmd", "/c", "code", *args] if IS_WINDOWS else ["code", *args]
    return subprocess.run(cmd, capture_output=True, text=True)


def list_extensions(profile_name):
    profile_args = () if profile_name == "Default" else ("--profile", profile_name)
    result = run_code(*profile_args, "--list-extensions")
    return {line.strip() for line in result.stdout.splitlines() if line.strip()}


def install_extension(profile_name, extension_id):
    profile_args = () if profile_name == "Default" else ("--profile", profile_name)
    print(f"Installing '{extension_id}' into VS Code profile '{profile_name}'...")
    run_code(*profile_args, "--install-extension", extension_id)


def sync_extensions(profile_name, desired_extensions):
    desired = set(desired_extensions)
    installed = list_extensions(profile_name)

    for extension_id in sorted(desired - installed):
        install_extension(profile_name, extension_id)

    extra = installed - desired
    if extra:
        print(
            f"{YELLOW_TERM_COLOR}Warning: VS Code profile '{profile_name}' has the following extensions "
            f"installed that aren't tracked by chezmoi. They have not been uninstalled, but you "
            f"should consider adding them to '.chezmoidata/vscode.toml': "
            f"{', '.join(sorted(extra))}{RESET_TERM_STYLE}",
            file=sys.stderr,
        )


def hash_string(value):
    return hashlib.sha256(value.encode("utf-8")).hexdigest()


def provision_profile(profile_name):
    # VS Code only registers a new profile in storage.json when it's opened as a real window, so
    # there's no way to create one headlessly. Open it ourselves and wait for the user to close it.
    print(
        f"{CYAN_TERM_COLOR}VS Code profile '{profile_name}' needs to be provisioned before chezmoi can manage "
        f"it. After you press Enter, VS Code will open with this profile. Close it once it appears. "
        f"This is a one-time process on this machine.{RESET_TERM_STYLE}"
    )
    input("Press Enter to continue... ")
    run_code("--profile", profile_name, "--wait")


def get_profile_location(user_dir, profile_name):
    storage_path = os.path.join(user_dir, "globalStorage", "storage.json")
    if not os.path.exists(storage_path):
        return None
    with open(storage_path, "r", encoding="utf-8") as f:
        storage = json.load(f)
    return next(
        (p.get("location") for p in storage.get("userDataProfiles", []) if p.get("name") == profile_name),
        None,
    )


def set_profile_icon(user_dir, profile_name, icon):
    # `code --profile "Name"` creates the profile but doesn't set its icon (it defaults to VS
    # Code's generic profile icon), so this patches it into storage.json to match vscode.toml.
    if not icon:
        return

    storage_path = os.path.join(user_dir, "globalStorage", "storage.json")
    with open(storage_path, "r", encoding="utf-8") as f:
        storage = json.load(f)

    changed = False
    for p in storage.get("userDataProfiles", []):
        if p.get("name") == profile_name:
            if p.get("icon") != icon:
                p["icon"] = icon
                changed = True
            break

    if not changed:
        return

    # Write to a temp file and rename over the original (atomic on both Windows and POSIX) rather
    # than writing storage.json in place, so a crash mid-write can't leave it corrupted.
    tmp_path = storage_path + ".chezmoi-tmp"
    with open(tmp_path, "w", encoding="utf-8", newline="") as f:
        json.dump(storage, f, indent=4)
    os.replace(tmp_path, storage_path)


def write_profile_settings(profile_name, profile_dir, settings_content):
    os.makedirs(profile_dir, exist_ok=True)
    settings_path = os.path.join(profile_dir, "settings.json")
    hash_path = os.path.join(profile_dir, "settings.json.chezmoi-hash")
    desired_path = os.path.join(profile_dir, "settings.json.chezmoi-desired")
    desired_hash = hash_string(settings_content)

    def write_settings():
        with open(settings_path, "w", encoding="utf-8", newline="") as f:
            f.write(settings_content)
        with open(hash_path, "w", encoding="utf-8", newline="") as f:
            f.write(desired_hash)
        if os.path.exists(desired_path):
            os.remove(desired_path)

    def warn_drifted(reason):
        # We're writing a copy of the contents here in case the source file is a template, which
        # couldn't be directly compared against. The copy will be cleaned up by future runs.
        with open(desired_path, "w", encoding="utf-8", newline="") as f:
            f.write(settings_content)
        print(
            f"{YELLOW_TERM_COLOR}Warning: VS Code profile '{profile_name}' {reason}.\n"
            f"\n"
            f"Compare it against what chezmoi would write with:\n"
            f"    code --diff \"{settings_path}\" \"{desired_path}\"\n"
            f"\n"
            f"Then either reconcile the differences manually, or run the following to have chezmoi\n"
            f"overwrite it automatically:\n"
            f"    {CLOBBER_COMMAND}{RESET_TERM_STYLE}",
            file=sys.stderr,
        )

    if not os.path.exists(settings_path):
        write_settings()
        return

    if not os.path.exists(hash_path):
        if CHEZMOI_VSCODE_CLOBBER:
            print(f"{CYAN_TERM_COLOR}VS Code profile '{profile_name}' had an untracked settings.json; "
                  f"overwriting it since CHEZMOI_VSCODE_CLOBBER is set.{RESET_TERM_STYLE}")
            write_settings()
            return
        warn_drifted("has a settings.json that is not chezmoi-managed")
        return

    with open(hash_path, "r", encoding="utf-8", newline="") as f:
        last_written_hash = f.read().strip()
    with open(settings_path, "r", encoding="utf-8", newline="") as f:
        live_hash = hash_string(f.read())

    if live_hash != last_written_hash:
        if CHEZMOI_VSCODE_CLOBBER:
            print(f"{CYAN_TERM_COLOR}VS Code profile '{profile_name}' had local changes to settings.json; "
                  f"overwriting them since CHEZMOI_VSCODE_CLOBBER is set.{RESET_TERM_STYLE}")
            write_settings()
            return
        warn_drifted("has local changes to settings.json that aren't tracked in chezmoi; leaving it as-is")
        return

    if os.path.exists(desired_path):
        os.remove(desired_path)

    if live_hash != desired_hash:
        write_settings()


def main():
    if not CODE_AVAILABLE:
        print("{YELLOW_TERM_COLOR}VS Code ('code' command) not found; skipping VS Code profile/extension sync.{RESET_TERM_STYLE}", file=sys.stderr)
        return

    user_dir = vscode_user_dir()

    for profile in PROFILES:
        name = profile["name"]

        if name == "Default":
            sync_extensions(name, profile["extensions"])
            continue

        location = get_profile_location(user_dir, name)
        if location is None:
            provision_profile(name)
            location = get_profile_location(user_dir, name)

        if location is None:
            print(
                f"{RED_TERM_COLOR}Error: VS Code profile '{name}' still isn't registered; skipping its extension "
                f"and settings sync this run. Re-run 'chezmoi apply' to try again.{RESET_TERM_STYLE}",
                file=sys.stderr,
            )
            continue

        set_profile_icon(user_dir, name, profile["icon"])
        sync_extensions(name, profile["extensions"])
        profile_dir = os.path.join(user_dir, "profiles", location)
        write_profile_settings(name, profile_dir, profile["settings"])


if __name__ == "__main__":
    main()
